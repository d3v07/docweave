# =============================================================================
# Graph Updater Service - Environment Configuration
# =============================================================================
# Copy this file to .env and configure for your environment.
# NEVER commit .env files with real credentials to version control.

# =============================================================================
# Security Configuration
# =============================================================================

# Admin API Key (REQUIRED for production)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# This key is required to access /admin/* endpoints
GRAPH_UPDATER_ADMIN_API_KEY=your-secure-api-key-here

# Environment (development, staging, production)
# In production mode, admin endpoints are disabled without a valid API key
ENVIRONMENT=development

# Rate Limiting
# Requests per minute per IP/user
RATE_LIMIT_RPM=60
# Requests per hour per IP/user
RATE_LIMIT_RPH=1000
# Burst allowance for traffic spikes
RATE_LIMIT_BURST=10

# CORS - Allowed Origins (comma-separated)
# Only these origins can make requests to the API
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# =============================================================================
# Database Configuration
# =============================================================================

# Neo4j Connection
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=devpassword123

# =============================================================================
# Kafka Configuration
# =============================================================================

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP_ID=graph-updater

# =============================================================================
# Service Configuration
# =============================================================================

# Service port
SERVICE_PORT=8004

# Log level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# =============================================================================
# Security Best Practices Checklist
# =============================================================================
# [ ] Generate a strong, unique GRAPH_UPDATER_ADMIN_API_KEY
# [ ] Set ENVIRONMENT=production in production
# [ ] Restrict ALLOWED_ORIGINS to your actual frontend domains
# [ ] Use HTTPS in production (not configured here - use reverse proxy)
# [ ] Rotate API keys periodically
# [ ] Monitor rate limit logs for potential abuse
# [ ] Never expose this file with real credentials
